# データベース接続設定
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=nasunest
MYSQL_USER=app_user
MYSQL_PASSWORD=app_password

# MySQL root パスワード（Docker Compose用）
MYSQL_ROOT_PASSWORD=rootpassword

# phpMyAdmin ポート（Docker Compose用）
PHPMYADMIN_PORT=8080

# 環境設定
NODE_ENV=development

# APIアクセス許可ホスト
ALLOWED_API_HOSTS=localhost
